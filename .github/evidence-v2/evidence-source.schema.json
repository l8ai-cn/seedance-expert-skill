{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Emily2040/seedance-2.0/.github/evidence-v2/evidence-source.schema.json",
  "title": "Seedance evidence source snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "source_snapshot_id",
    "source_id",
    "title",
    "source_url",
    "source_type",
    "publisher",
    "original_language",
    "document_updated_at",
    "retrieved_at",
    "retrieval_status",
    "retrieval_method",
    "retrieved_document_sha256",
    "capture_path"
  ],
  "properties": {
    "$schema": {"type": "string", "const": "../evidence-source.schema.json"},
    "source_snapshot_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)+$"},
    "source_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)+$"},
    "title": {"type": "string", "minLength": 1},
    "source_url": {"type": ["string", "null"], "format": "uri"},
    "source_type": {
      "enum": [
        "first_party_model_doc",
        "first_party_platform_doc",
        "provider_owned_doc",
        "research_paper",
        "community_source",
        "user_supplied_material",
        "internal_record"
      ]
    },
    "publisher": {"type": "string", "minLength": 1},
    "original_language": {"type": "string", "minLength": 2},
    "document_updated_at": {"type": ["string", "null"], "format": "date"},
    "retrieved_at": {"type": "string", "format": "date"},
    "retrieval_status": {"enum": ["fetched", "browser_verified", "provided", "blocked", "missing"]},
    "retrieval_method": {"type": "string", "minLength": 1},
    "retrieved_document_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "capture_path": {"type": ["string", "null"], "minLength": 1}
  }
}
