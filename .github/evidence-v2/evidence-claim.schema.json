{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Emily2040/seedance-2.0/.github/evidence-v2/evidence-claim.schema.json",
  "title": "Seedance atomic evidence claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "claim_id",
    "claim_text",
    "normalized_key",
    "value",
    "model_family",
    "model_version",
    "claim_class",
    "scope",
    "support_status",
    "volatility",
    "agreement_status",
    "lifecycle_status",
    "runtime_eligible",
    "runtime_disposition",
    "source_snapshot_id",
    "source_locator",
    "evidence_summary",
    "evidence_summary_sha256",
    "verified_at",
    "expires_at",
    "supersedes",
    "relations",
    "conflict_group",
    "affected_paths",
    "review"
  ],
  "properties": {
    "$schema": {"type": "string", "const": "../evidence-claim.schema.json"},
    "claim_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$"},
    "claim_text": {"type": "string", "minLength": 20},
    "normalized_key": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)+$"},
    "value": {
      "oneOf": [
        {"type": "string"},
        {"type": "number"},
        {"type": "boolean"},
        {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true}
      ]
    },
    "model_family": {"type": "string", "minLength": 1},
    "model_version": {"type": "string", "minLength": 1},
    "claim_class": {
      "enum": [
        "pricing",
        "model_id",
        "api_field",
        "prompt_grammar",
        "model_capability",
        "workflow",
        "official_example",
        "release_watchlist",
        "community_pattern"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surfaces", "tasks", "locale", "region"],
      "properties": {
        "surfaces": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "tasks": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "locale": {"type": "string", "minLength": 2},
        "region": {"type": "string", "minLength": 2}
      }
    },
    "support_status": {"enum": ["supported", "unverified", "retracted"]},
    "volatility": {"enum": ["stable", "volatile", "unknown"]},
    "agreement_status": {"enum": ["not_assessed", "uncontested", "qualified", "conflicting"]},
    "lifecycle_status": {"enum": ["active", "expired", "superseded"]},
    "runtime_eligible": {"const": false, "description": "Foundation phase is evidence-only; activation is schema-locked."},
    "runtime_disposition": {"enum": ["allow", "warn", "defer", "block"]},
    "source_snapshot_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)+$"},
    "source_locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["heading_path", "fragment_hint", "captured_lines"],
      "properties": {
        "heading_path": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
        "fragment_hint": {"type": ["string", "null"]},
        "captured_lines": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "array",
              "prefixItems": [{"type": "integer", "minimum": 1}, {"type": "integer", "minimum": 1}],
              "minItems": 2,
              "maxItems": 2
            }
          ]
        }
      }
    },
    "evidence_summary": {"type": "string", "minLength": 20},
    "evidence_summary_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "verified_at": {"type": "string", "format": "date"},
    "expires_at": {"type": "string", "format": "date"},
    "supersedes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "type"],
        "properties": {
          "claim_id": {"type": "string"},
          "type": {"enum": ["supports", "supported_by", "qualifies", "qualified_by", "tension_with"]}
        }
      },
      "uniqueItems": true
    },
    "conflict_group": {"type": ["string", "null"], "minLength": 1},
    "affected_paths": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewers"],
      "properties": {
        "status": {"enum": ["pending", "approved", "rejected"]},
        "reviewers": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    },
    "notes": {"type": "string"}
  }
}
