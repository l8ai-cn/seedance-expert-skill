{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Emily2040/seedance-2.0/evals/eval-suite-v2.schema.json",
  "title": "Seedance Eval Suite v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "suite_id", "kind", "case_file", "expected_case_count", "release_eligible", "description"],
  "properties": {
    "$schema": {"const": "https://github.com/Emily2040/seedance-2.0/evals/eval-suite-v2.schema.json"},
    "schema_version": {"const": 2},
    "suite_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "kind": {"enum": ["development", "live", "held_out"]},
    "case_file": {"type": "string", "minLength": 1},
    "expected_case_count": {"type": "integer", "minimum": 1},
    "release_eligible": {"type": "boolean"},
    "description": {"type": "string", "minLength": 1},
    "include_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"}
    }
  }
}
