{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Emily2040/seedance-2.0/schemas/scene-ir-v2.schema.json",
  "title": "Seedance V7-09 state-bound audio and multi-shot scene IR v2",
  "$comment": "Candidate-only semantic plan. Runtime additionally enforces ID uniqueness, causal and adjacent transition graphs, state/timing policy alignment, exact UTF-8 utterance hashes, voice authorization, contiguous speech turns and audio shot scopes, and complete acceptance coverage.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "state_binding",
    "take_structure",
    "timing_policy",
    "entities",
    "materials",
    "speakers",
    "shots",
    "transitions",
    "audio_events",
    "subtitle_policy",
    "requested_invariants",
    "known_fragilities",
    "acceptance_tests",
    "post_fallbacks"
  ],
  "properties": {
    "$schema": {
      "const": "https://github.com/Emily2040/seedance-2.0/schemas/scene-ir-v2.schema.json"
    },
    "schema_version": {"const": 2},
    "state_binding": {"$ref": "#/$defs/state_binding"},
    "take_structure": {
      "enum": ["single_continuous_take", "edited_multi_shot"]
    },
    "timing_policy": {
      "enum": ["ordered_phases", "relative_beats", "surface_exact_ranges"]
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"$ref": "#/$defs/entity"}
    },
    "materials": {
      "type": "array",
      "maxItems": 128,
      "items": {"$ref": "#/$defs/material"}
    },
    "speakers": {
      "type": "array",
      "maxItems": 32,
      "items": {"$ref": "#/$defs/speaker"}
    },
    "shots": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {"$ref": "#/$defs/shot"}
    },
    "transitions": {
      "type": "array",
      "maxItems": 31,
      "items": {"$ref": "#/$defs/transition"}
    },
    "audio_events": {
      "type": "array",
      "maxItems": 128,
      "items": {"$ref": "#/$defs/audio_event"}
    },
    "subtitle_policy": {"$ref": "#/$defs/subtitle_policy"},
    "requested_invariants": {
      "type": "array",
      "maxItems": 128,
      "items": {"$ref": "#/$defs/requested_invariant"}
    },
    "known_fragilities": {
      "type": "array",
      "maxItems": 128,
      "items": {"$ref": "#/$defs/known_fragility"}
    },
    "acceptance_tests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {"$ref": "#/$defs/acceptance_test"}
    },
    "post_fallbacks": {
      "type": "array",
      "maxItems": 128,
      "items": {"$ref": "#/$defs/post_fallback"}
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]{0,63}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "nullable_id": {
      "oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]
    },
    "nullable_sha": {
      "oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
    },
    "bounded_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "not": {"pattern": "(?:https?://|file://)"}
    },
    "id_array": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/id"}
    },
    "state_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "clip_id",
        "state_revision",
        "canon_revision",
        "semantic_state_sha256",
        "planned_start_snapshot_sha256",
        "planned_end_snapshot_sha256",
        "completed_beat_ids",
        "current_beat_ids",
        "reserved_future_beat_ids"
      ],
      "properties": {
        "project_id": {"$ref": "#/$defs/id"},
        "clip_id": {"$ref": "#/$defs/id"},
        "state_revision": {"type": "integer", "minimum": 1},
        "canon_revision": {"type": "integer", "minimum": 1},
        "semantic_state_sha256": {"$ref": "#/$defs/sha256"},
        "planned_start_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "planned_end_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "completed_beat_ids": {"$ref": "#/$defs/id_array"},
        "current_beat_ids": {"$ref": "#/$defs/id_array"},
        "reserved_future_beat_ids": {"$ref": "#/$defs/id_array"}
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_id", "label", "kind", "stable_features"],
      "properties": {
        "entity_id": {"$ref": "#/$defs/id"},
        "label": {"$ref": "#/$defs/bounded_text"},
        "kind": {
          "enum": ["character", "product", "object", "environment", "effect", "text"]
        },
        "stable_features": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/bounded_text"}
        }
      }
    },
    "material": {
      "type": "object",
      "additionalProperties": false,
      "required": ["material_id", "entity_id", "kind", "response_properties"],
      "properties": {
        "material_id": {"$ref": "#/$defs/id"},
        "entity_id": {"$ref": "#/$defs/id"},
        "kind": {
          "enum": ["rigid", "elastic", "fabric", "liquid", "granular", "organic", "smoke", "fire", "other"]
        },
        "response_properties": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/bounded_text"}
        }
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "authority_target_id", "asset_id", "authorization_status", "attestation_sha256"],
      "properties": {
        "mode": {
          "enum": ["generic_synthetic", "authorized_reference", "post_dub"]
        },
        "authority_target_id": {"$ref": "#/$defs/nullable_id"},
        "asset_id": {"$ref": "#/$defs/nullable_id"},
        "authorization_status": {
          "enum": ["not_applicable", "user_attested_authorized", "unknown", "not_authorized"]
        },
        "attestation_sha256": {"$ref": "#/$defs/nullable_sha"}
      },
      "allOf": [
        {
          "if": {"properties": {"mode": {"const": "generic_synthetic"}}, "required": ["mode"]},
          "then": {
            "properties": {
              "authority_target_id": {"type": "null"},
              "asset_id": {"type": "null"},
              "authorization_status": {"const": "not_applicable"},
              "attestation_sha256": {"type": "null"}
            }
          }
        },
        {
          "if": {"properties": {"mode": {"const": "authorized_reference"}}, "required": ["mode"]},
          "then": {
            "properties": {
              "authority_target_id": {"$ref": "#/$defs/id"},
              "asset_id": {"$ref": "#/$defs/id"},
              "authorization_status": {"const": "user_attested_authorized"},
              "attestation_sha256": {"$ref": "#/$defs/sha256"}
            }
          }
        },
        {
          "if": {"properties": {"mode": {"const": "post_dub"}}, "required": ["mode"]},
          "then": {
            "properties": {
              "authority_target_id": {"type": "null"},
              "asset_id": {"type": "null"},
              "attestation_sha256": {"type": "null"}
            }
          }
        }
      ]
    },
    "speaker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["speaker_id", "entity_id", "role", "display_name", "voice"],
      "properties": {
        "speaker_id": {"$ref": "#/$defs/id"},
        "entity_id": {"$ref": "#/$defs/nullable_id"},
        "role": {
          "enum": ["onscreen_character", "offscreen_character", "narrator"]
        },
        "display_name": {"$ref": "#/$defs/bounded_text"},
        "voice": {"$ref": "#/$defs/voice"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"role": {"enum": ["onscreen_character", "offscreen_character"]}},
            "required": ["role"]
          },
          "then": {"properties": {"entity_id": {"$ref": "#/$defs/id"}}}
        }
      ]
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_index",
        "phase",
        "actor_ids",
        "target_ids",
        "depends_on",
        "visible_state_change",
        "beat_ids",
        "interaction_kind",
        "material_ids"
      ],
      "properties": {
        "event_id": {"$ref": "#/$defs/id"},
        "event_index": {"type": "integer", "minimum": 1, "maximum": 64},
        "phase": {
          "enum": ["opening_state", "action", "interaction_or_state_change", "response", "follow_through", "endpoint"]
        },
        "actor_ids": {"$ref": "#/$defs/id_array"},
        "target_ids": {"$ref": "#/$defs/id_array"},
        "depends_on": {"$ref": "#/$defs/id_array"},
        "visible_state_change": {"$ref": "#/$defs/bounded_text"},
        "beat_ids": {"$ref": "#/$defs/id_array"},
        "interaction_kind": {
          "enum": ["none", "contact", "material_change", "non_material_state_change"]
        },
        "material_ids": {"$ref": "#/$defs/id_array"}
      },
      "anyOf": [
        {"properties": {"actor_ids": {"minItems": 1}}},
        {"properties": {"target_ids": {"minItems": 1}}}
      ]
    },
    "camera": {
      "type": "object",
      "additionalProperties": false,
      "required": ["move_kind", "start_framing", "path", "speed", "subject_relationship", "endpoint_framing", "observed_event_ids", "occlusion_risks", "mitigations"],
      "properties": {
        "move_kind": {
          "enum": ["locked", "push_in", "pull_out", "pan", "tilt", "tracking", "orbit", "crane", "dolly", "handheld"]
        },
        "start_framing": {"$ref": "#/$defs/bounded_text"},
        "path": {"$ref": "#/$defs/bounded_text"},
        "speed": {"$ref": "#/$defs/bounded_text"},
        "subject_relationship": {"$ref": "#/$defs/bounded_text"},
        "endpoint_framing": {"$ref": "#/$defs/bounded_text"},
        "observed_event_ids": {
          "allOf": [{"$ref": "#/$defs/id_array"}, {"minItems": 2}]
        },
        "occlusion_risks": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/bounded_text"}
        },
        "mitigations": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/bounded_text"}
        }
      }
    },
    "shot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shot_id", "shot_index", "opening_event_id", "endpoint_event_id", "events", "camera"],
      "properties": {
        "shot_id": {"$ref": "#/$defs/id"},
        "shot_index": {"type": "integer", "minimum": 1, "maximum": 32},
        "opening_event_id": {"$ref": "#/$defs/id"},
        "endpoint_event_id": {"$ref": "#/$defs/id"},
        "events": {
          "type": "array",
          "minItems": 2,
          "maxItems": 64,
          "items": {"$ref": "#/$defs/event"}
        },
        "camera": {"$ref": "#/$defs/camera"}
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transition_id", "transition_index", "from_shot_id", "to_shot_id", "transition_type", "from_event_id", "to_event_id", "beat_ids", "preserved_invariant_ids", "allowed_change_event_ids", "audio_bridge_event_ids"],
      "properties": {
        "transition_id": {"$ref": "#/$defs/id"},
        "transition_index": {"type": "integer", "minimum": 1, "maximum": 31},
        "from_shot_id": {"$ref": "#/$defs/id"},
        "to_shot_id": {"$ref": "#/$defs/id"},
        "transition_type": {
          "enum": ["hard_cut", "match_cut", "dissolve", "fade"]
        },
        "from_event_id": {"$ref": "#/$defs/id"},
        "to_event_id": {"$ref": "#/$defs/id"},
        "beat_ids": {
          "allOf": [{"$ref": "#/$defs/id_array"}, {"minItems": 1}]
        },
        "preserved_invariant_ids": {"$ref": "#/$defs/id_array"},
        "allowed_change_event_ids": {"$ref": "#/$defs/id_array"},
        "audio_bridge_event_ids": {"$ref": "#/$defs/id_array"}
      }
    },
    "audio_timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "start_event_id", "end_event_id", "cue_event_id", "beat_label", "start_seconds", "end_seconds", "evidence_claim_ids"],
      "properties": {
        "mode": {
          "enum": ["visual_event_window", "continuous_shot", "continuous_sequence", "relative_beat", "surface_exact_range"]
        },
        "start_event_id": {"$ref": "#/$defs/nullable_id"},
        "end_event_id": {"$ref": "#/$defs/nullable_id"},
        "cue_event_id": {"$ref": "#/$defs/nullable_id"},
        "beat_label": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 200
        },
        "start_seconds": {"type": ["number", "null"], "minimum": 0, "maximum": 60},
        "end_seconds": {"type": ["number", "null"], "exclusiveMinimum": 0, "maximum": 60},
        "evidence_claim_ids": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$"
          }
        }
      }
    },
    "speech": {
      "type": "object",
      "additionalProperties": false,
      "required": ["speaker_id", "spoken_language", "utterance", "utterance_sha256", "turn_index", "overlap_policy", "lip_sync", "delivery_intent"],
      "properties": {
        "speaker_id": {"$ref": "#/$defs/id"},
        "spoken_language": {
          "type": "string",
          "maxLength": 63,
          "pattern": "^[a-z]{2,8}(?:-[A-Z][a-z]{3})?(?:-(?:[A-Z]{2}|[0-9]{3}))?(?:-(?:[a-z0-9]{5,8}|[0-9][a-z0-9]{3}))*$"
        },
        "utterance": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "utterance_sha256": {"$ref": "#/$defs/sha256"},
        "turn_index": {"type": "integer", "minimum": 1, "maximum": 128},
        "overlap_policy": {"enum": ["no_overlap", "overlap_allowed"]},
        "lip_sync": {"enum": ["required", "not_required", "post_only"]},
        "delivery_intent": {"$ref": "#/$defs/bounded_text"}
      }
    },
    "audio_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["audio_event_id", "audio_event_index", "semantic_function", "shot_ids", "beat_ids", "source_entity_ids", "timing", "description", "speech"],
      "properties": {
        "audio_event_id": {"$ref": "#/$defs/id"},
        "audio_event_index": {"type": "integer", "minimum": 1, "maximum": 128},
        "semantic_function": {
          "enum": ["dialogue", "voiceover", "sound_effect", "ambience", "music", "rhythm", "silence"]
        },
        "shot_ids": {
          "allOf": [{"$ref": "#/$defs/id_array"}, {"minItems": 1, "maxItems": 32}]
        },
        "beat_ids": {
          "allOf": [{"$ref": "#/$defs/id_array"}, {"minItems": 1}]
        },
        "source_entity_ids": {"$ref": "#/$defs/id_array"},
        "timing": {"$ref": "#/$defs/audio_timing"},
        "description": {"$ref": "#/$defs/bounded_text"},
        "speech": {
          "oneOf": [{"$ref": "#/$defs/speech"}, {"type": "null"}]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"semantic_function": {"enum": ["dialogue", "voiceover"]}},
            "required": ["semantic_function"]
          },
          "then": {"properties": {"speech": {"$ref": "#/$defs/speech"}}},
          "else": {"properties": {"speech": {"type": "null"}}}
        }
      ]
    },
    "subtitle_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "target_language_tags", "picture_policy"],
      "properties": {
        "mode": {
          "enum": ["none", "post_subtitles", "post_sdh_captions", "post_forced_narrative"]
        },
        "target_language_tags": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "maxLength": 63,
            "pattern": "^[a-z]{2,8}(?:-[A-Z][a-z]{3})?(?:-(?:[A-Z]{2}|[0-9]{3}))?(?:-(?:[a-z0-9]{5,8}|[0-9][a-z0-9]{3}))*$"
          }
        },
        "picture_policy": {"enum": ["clean_picture", "not_applicable"]}
      },
      "allOf": [
        {
          "if": {"properties": {"mode": {"const": "none"}}, "required": ["mode"]},
          "then": {
            "properties": {
              "target_language_tags": {"maxItems": 0},
              "picture_policy": {"const": "not_applicable"}
            }
          },
          "else": {
            "properties": {
              "target_language_tags": {"minItems": 1},
              "picture_policy": {"const": "clean_picture"}
            }
          }
        }
      ]
    },
    "requested_invariant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invariant_id", "entity_ids", "description"],
      "properties": {
        "invariant_id": {"$ref": "#/$defs/id"},
        "entity_ids": {
          "allOf": [{"$ref": "#/$defs/id_array"}, {"minItems": 1}]
        },
        "description": {"$ref": "#/$defs/bounded_text"}
      }
    },
    "known_fragility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fragility_id", "event_ids", "audio_event_ids", "transition_ids", "description"],
      "properties": {
        "fragility_id": {"$ref": "#/$defs/id"},
        "event_ids": {"$ref": "#/$defs/id_array"},
        "audio_event_ids": {"$ref": "#/$defs/id_array"},
        "transition_ids": {"$ref": "#/$defs/id_array"},
        "description": {"$ref": "#/$defs/bounded_text"}
      },
      "anyOf": [
        {"properties": {"event_ids": {"minItems": 1}}},
        {"properties": {"audio_event_ids": {"minItems": 1}}},
        {"properties": {"transition_ids": {"minItems": 1}}}
      ]
    },
    "acceptance_test": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptance_id", "event_ids", "audio_event_ids", "transition_ids", "observable", "pass_condition"],
      "properties": {
        "acceptance_id": {"$ref": "#/$defs/id"},
        "event_ids": {"$ref": "#/$defs/id_array"},
        "audio_event_ids": {"$ref": "#/$defs/id_array"},
        "transition_ids": {"$ref": "#/$defs/id_array"},
        "observable": {"$ref": "#/$defs/bounded_text"},
        "pass_condition": {"$ref": "#/$defs/bounded_text"}
      },
      "anyOf": [
        {"properties": {"event_ids": {"minItems": 1}}},
        {"properties": {"audio_event_ids": {"minItems": 1}}},
        {"properties": {"transition_ids": {"minItems": 1}}}
      ]
    },
    "post_fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fallback_id", "trigger_acceptance_ids", "action"],
      "properties": {
        "fallback_id": {"$ref": "#/$defs/id"},
        "trigger_acceptance_ids": {
          "allOf": [{"$ref": "#/$defs/id_array"}, {"minItems": 1}]
        },
        "action": {"$ref": "#/$defs/bounded_text"}
      }
    }
  }
}
