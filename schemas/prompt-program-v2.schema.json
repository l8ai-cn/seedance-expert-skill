{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Emily2040/seedance-2.0/schemas/prompt-program-v2.schema.json",
  "title": "Seedance V7-09 surface-independent AV prompt program",
  "$comment": "Candidate-only ordered provenance. Exact speech bypasses localization; review/post units cannot enter prompt emission; typed bindings remain request-carried.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "status", "state_binding", "state_binding_sha256", "scene_ir_sha256", "surface_av_policy_sha256", "surface_binding_set_sha256", "realization_catalog_sha256", "policy_provenance", "take_structure", "timing_policy", "ordering", "units"],
  "properties": {
    "$schema": {"const": "https://github.com/Emily2040/seedance-2.0/schemas/prompt-program-v2.schema.json"},
    "schema_version": {"const": 2},
    "status": {"enum": ["candidate_preview", "unattested_fixture_preview"]},
    "state_binding": {"$ref": "#/$defs/state_binding"},
    "state_binding_sha256": {"$ref": "#/$defs/sha256"},
    "scene_ir_sha256": {"$ref": "#/$defs/sha256"},
    "surface_av_policy_sha256": {"$ref": "#/$defs/sha256"},
    "surface_binding_set_sha256": {"$ref": "#/$defs/sha256"},
    "realization_catalog_sha256": {"$ref": "#/$defs/sha256"},
    "policy_provenance": {"$ref": "#/$defs/policy_provenance"},
    "take_structure": {"enum": ["single_continuous_take", "edited_multi_shot"]},
    "timing_policy": {"enum": ["ordered_phases", "relative_beats", "surface_exact_ranges"]},
    "ordering": {"$ref": "#/$defs/ordering"},
    "units": {"type": "array", "minItems": 1, "maxItems": 10000, "items": {"$ref": "#/$defs/unit"}}
  },
  "allOf": [
    {
      "if": {"properties": {"policy_provenance": {"properties": {"policy_kind": {"const": "unattested_fixture"}}, "required": ["policy_kind"]}}, "required": ["policy_provenance"]},
      "then": {"properties": {"status": {"const": "unattested_fixture_preview"}}},
      "else": {"properties": {"status": {"const": "candidate_preview"}}}
    }
  ],
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "id_array": {"type": "array", "maxItems": 4096, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "semantic_key": {"type": "string", "pattern": "^(?:entity\\.[a-z][a-z0-9._-]{0,63}\\.label|speaker\\.[a-z][a-z0-9._-]{0,63}\\.display_name|event\\.[a-z][a-z0-9._-]{0,63}\\.visible_state_change|shot\\.[a-z][a-z0-9._-]{0,63}\\.camera\\.(?:start_framing|path|speed|subject_relationship|endpoint_framing)|audio\\.[a-z][a-z0-9._-]{0,63}\\.(?:description|delivery_intent)|invariant\\.[a-z][a-z0-9._-]{0,63}\\.description)$"},
    "state_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["project_id", "clip_id", "state_revision", "canon_revision", "semantic_state_sha256", "planned_start_snapshot_sha256", "planned_end_snapshot_sha256", "completed_beat_ids", "current_beat_ids", "reserved_future_beat_ids"],
      "properties": {
        "project_id": {"$ref": "#/$defs/id"}, "clip_id": {"$ref": "#/$defs/id"},
        "state_revision": {"type": "integer", "minimum": 1}, "canon_revision": {"type": "integer", "minimum": 1},
        "semantic_state_sha256": {"$ref": "#/$defs/sha256"}, "planned_start_snapshot_sha256": {"$ref": "#/$defs/sha256"}, "planned_end_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "completed_beat_ids": {"$ref": "#/$defs/id_array"}, "current_beat_ids": {"$ref": "#/$defs/id_array"}, "reserved_future_beat_ids": {"$ref": "#/$defs/id_array"}
      }
    },
    "policy_provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["policy_id", "policy_kind", "profile_id", "operation", "model_profile_id", "model_variant", "region", "provider_locale", "surface_profile_sha256", "model_profile_sha256"],
      "properties": {
        "policy_id": {"$ref": "#/$defs/id"}, "policy_kind": {"enum": ["evidence_pinned", "unattested_fixture"]},
        "profile_id": {"$ref": "#/$defs/id"}, "operation": {"enum": ["reference_generation", "first_last_frame"]},
        "model_profile_id": {"$ref": "#/$defs/id"}, "model_variant": {"$ref": "#/$defs/id"},
        "region": {"type": "string", "minLength": 2, "maxLength": 16}, "provider_locale": {"enum": ["global", "cn", "unknown"]},
        "surface_profile_sha256": {"$ref": "#/$defs/sha256"}, "model_profile_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "ordering": {
      "type": "object", "additionalProperties": false,
      "required": ["transition_ids", "audio_event_ids", "speech_event_ids", "speech_turn_indices"],
      "properties": {
        "transition_ids": {"$ref": "#/$defs/id_array"}, "audio_event_ids": {"$ref": "#/$defs/id_array"}, "speech_event_ids": {"$ref": "#/$defs/id_array"},
        "speech_turn_indices": {"type": "array", "maxItems": 128, "items": {"type": "integer", "minimum": 1, "maximum": 128}}
      }
    },
    "unit": {
      "type": "object", "additionalProperties": false,
      "required": ["unit_id", "kind", "emission", "source_ids", "shot_ids", "semantic_key", "content_sha256", "speaker_id", "spoken_language", "turn_index"],
      "properties": {
        "unit_id": {"$ref": "#/$defs/id"},
        "kind": {"enum": ["state", "take", "shot", "event", "camera", "transition", "audio", "audio_timing", "speech_delivery", "speech_overlap", "speech_lip_sync", "exact_speech", "invariant", "subtitle", "voice_binding", "binding", "review", "post_fallback"]},
        "emission": {"enum": ["prompt", "post_only", "request_carried", "review_only"]},
        "source_ids": {"$ref": "#/$defs/id_array"}, "shot_ids": {"$ref": "#/$defs/id_array"},
        "semantic_key": {"oneOf": [{"$ref": "#/$defs/semantic_key"}, {"type": "null"}]},
        "content_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "speaker_id": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
        "spoken_language": {"type": ["string", "null"], "maxLength": 63},
        "turn_index": {"type": ["integer", "null"], "minimum": 1, "maximum": 128}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "exact_speech"}}, "required": ["kind"]}, "then": {"properties": {"semantic_key": {"type": "null"}, "content_sha256": {"$ref": "#/$defs/sha256"}, "speaker_id": {"$ref": "#/$defs/id"}, "spoken_language": {"type": "string", "minLength": 2}, "turn_index": {"type": "integer"}}}},
        {"if": {"properties": {"kind": {"const": "speech_delivery"}}, "required": ["kind"]}, "then": {"properties": {"semantic_key": {"$ref": "#/$defs/semantic_key"}, "speaker_id": {"$ref": "#/$defs/id"}}}},
        {"if": {"properties": {"kind": {"enum": ["speech_overlap", "speech_lip_sync"]}}, "required": ["kind"]}, "then": {"properties": {"semantic_key": {"type": "null"}, "content_sha256": {"$ref": "#/$defs/sha256"}, "speaker_id": {"$ref": "#/$defs/id"}}}},
        {"if": {"properties": {"kind": {"const": "audio_timing"}}, "required": ["kind"]}, "then": {"properties": {"semantic_key": {"type": "null"}, "content_sha256": {"$ref": "#/$defs/sha256"}}}},
        {"if": {"properties": {"kind": {"const": "voice_binding"}}, "required": ["kind"]}, "then": {"properties": {"emission": {"const": "request_carried"}, "semantic_key": {"type": "null"}, "content_sha256": {"$ref": "#/$defs/sha256"}, "speaker_id": {"$ref": "#/$defs/id"}}}},
        {"if": {"properties": {"kind": {"enum": ["state", "binding"]}}, "required": ["kind"]}, "then": {"properties": {"emission": {"const": "request_carried"}}}},
        {"if": {"properties": {"kind": {"const": "review"}}, "required": ["kind"]}, "then": {"properties": {"emission": {"const": "review_only"}}}},
        {"if": {"properties": {"kind": {"enum": ["subtitle", "post_fallback"]}}, "required": ["kind"]}, "then": {"properties": {"emission": {"const": "post_only"}}}}
      ]
    }
  }
}
