{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Emily2040/seedance-2.0/schemas/prompt-realization-catalog-v2.schema.json",
  "title": "Seedance V7-09 AV realization catalog",
  "$comment": "Localizes directing prose only. Exact speech utterances and post-dub content are forbidden from this catalog and remain hash-bound scene data.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "scene_ir_sha256", "attestation", "entries"],
  "properties": {
    "$schema": {"const": "https://github.com/Emily2040/seedance-2.0/schemas/prompt-realization-catalog-v2.schema.json"},
    "schema_version": {"const": 2},
    "scene_ir_sha256": {"$ref": "#/$defs/sha256"},
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "linguistic_equivalence", "locales"],
      "properties": {
        "method": {"enum": ["user_attested", "reviewer_attested", "unattested_fixture"]},
        "linguistic_equivalence": {"enum": ["human_asserted", "not_attested"]},
        "locales": {"const": ["en", "zh-Hans"]}
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/entry"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "semantic_key": {
      "type": "string",
      "pattern": "^(?:entity\\.[a-z][a-z0-9._-]{0,63}\\.label|speaker\\.[a-z][a-z0-9._-]{0,63}\\.display_name|event\\.[a-z][a-z0-9._-]{0,63}\\.visible_state_change|shot\\.[a-z][a-z0-9._-]{0,63}\\.camera\\.(?:start_framing|path|speed|subject_relationship|endpoint_framing)|audio\\.[a-z][a-z0-9._-]{0,63}\\.(?:description|delivery_intent)|invariant\\.[a-z][a-z0-9._-]{0,63}\\.description)$"
    },
    "localized_text": {"type": "string", "minLength": 1, "maxLength": 1000},
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["semantic_key", "source_sha256", "en", "zh_hans"],
      "properties": {
        "semantic_key": {"$ref": "#/$defs/semantic_key"},
        "source_sha256": {"$ref": "#/$defs/sha256"},
        "en": {"$ref": "#/$defs/localized_text"},
        "zh_hans": {"$ref": "#/$defs/localized_text"}
      }
    }
  }
}
